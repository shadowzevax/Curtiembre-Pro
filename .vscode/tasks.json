{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "💾 Guardar nueva versión",
      "type": "shell",
      "command": "node scripts/version.mjs guardar \"${input:descripcion}\"",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "new", "focus": true }
    },
    {
      "label": "📋 Ver versiones guardadas",
      "type": "shell",
      "command": "node scripts/version.mjs listar",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "new", "focus": true }
    },
    {
      "label": "⏪ Restaurar versión",
      "type": "shell",
      "command": "node scripts/version.mjs restaurar",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "new", "focus": true }
    }
  ],
  "inputs": [
    {
      "id": "descripcion",
      "type": "promptString",
      "description": "¿Qué cambió en esta versión? (descripción corta)"
    }
  ]
}
